# Database
DATABASE_URL="postgresql://user:password@localhost:5432/bizopt?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-long-random-secret"

# Stripe (USD default for MVP)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID="price_..."
STRIPE_TRIAL_FEE_PRICE_ID="price_..."
TRIAL_PRICE_CENTS=99
TRIAL_DAYS=7
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
BILLING_CURRENCY="usd"
SUBSCRIPTION_AMOUNT_CENTS=999

# Device binding
DEVICE_SECRET="generate-device-binding-secret"

# Object storage (optional — defaults to public/uploads)
S3_BUCKET=""
S3_REGION="auto"
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL=""

# AI (optional)
OPENAI_API_KEY=""

# Social OAuth (optional)
META_APP_ID=""
META_APP_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
