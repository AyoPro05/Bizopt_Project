# ============================================================
# CRITICAL (REQUIRED) — App will not start without these
# ============================================================
# Database
DATABASE_URL="postgresql://user:password@localhost:5432/bizopt?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-long-random-secret-min-32-chars"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID="price_..."
STRIPE_TRIAL_FEE_PRICE_ID="price_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Device binding
DEVICE_SECRET="generate-device-binding-secret-min-32-chars"

# ============================================================
# IMPORTANT (RECOMMENDED) — Production experience depends on these
# ============================================================
# Billing
BILLING_CURRENCY="usd"
SUBSCRIPTION_AMOUNT_CENTS=999
TRIAL_PRICE_CENTS=99
TRIAL_DAYS=7

# Mobile API (defaults to NEXTAUTH_SECRET if unset)
MOBILE_JWT_SECRET=""

# Email Verification & Notifications (Resend)
# Get free API key at: https://resend.com (starts free, $0.75/email at scale)
RESEND_API_KEY="re_..."

# ============================================================
# OPTIONAL — Features degrade gracefully if unset
# ============================================================
# AI Content Generation (falls back to templates if unset)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Object Storage (use S3 or compatible; unset to use local storage)
S3_BUCKET=""
S3_REGION="auto"
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL=""

# Social Platform OAuth
META_APP_ID=""
META_APP_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# Development Only
ALLOW_DEMO_OAUTH="true"

# ============================================================
# DEPLOYMENT NOTES
# ============================================================
# 1. Generate secrets with: openssl rand -base64 32
# 2. For Render: Set env vars in Render dashboard before deploy
# 3. Database: Use Render's managed Postgres or external PostgreSQL
# 4. Never commit .env to git (use .env.local / .env.production.local)
# 5. Email: Sign up free at https://resend.com for email verification
